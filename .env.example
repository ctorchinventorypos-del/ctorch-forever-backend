# ============================================================
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit the real .env to git (it holds secrets).
# ============================================================

# ---- Database -----------------------------------------------
# Paste the "External Database URL" from your Render Postgres dashboard.
DATABASE_URL=postgresql://jedidiah:wnri1bfnlsnxE0HrpZci0qMBNp2wagCh@dpg-d8ord6r6sc1c73c3n1i0-a.frankfurt-postgres.render.com/ctorch_forever_nigeria
# Render requires SSL. Leave as true. Only set false for a local DB.
DATABASE_SSL=true

# ---- Auth ---------------------------------------------------
# A long random secret used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=12h

# ---- Server -------------------------------------------------
PORT=4000
NODE_ENV=development

# ---- CORS ---------------------------------------------------
# Where your frontend runs. Comma-separated if more than one.
CORS_ORIGIN=http://localhost:5173

# ---- First admin (used once by:  npm run seed) --------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_FULLNAME=System Administrator
